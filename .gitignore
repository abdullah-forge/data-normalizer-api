# .gitignore

# ============================================
# PYTHON
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ============================================
# VIRTUAL ENVIRONMENT
# ============================================
venv/
.venv/
env/
ENV/

# ============================================
# ENVIRONMENT FILES (SECRETS)
# ============================================
.env
.env.local
.env.*.local

# ============================================
# IDE / EDITOR
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# PROJECT SPECIFIC - DATA FILES
# ============================================
data/uploads/
data/outputs/
data/*.csv
data/*.xlsx
data/*.xls
data/*.json

# ============================================
# DATABASE
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# TESTING
# ============================================
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ============================================
# LOGS
# ============================================
*.log
logs/

# ============================================
# DOCKER (NEXT WEEK )
# ============================================
docker-compose.override.yml
